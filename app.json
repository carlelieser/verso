{
  "expo": {
    "name": "Verso",
    "slug": "verso",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "verso",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1C"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for voice dictation",
        "NSLocationWhenInUseUsageDescription": "Used to tag entries with your location",
        "NSPhotoLibraryUsageDescription": "Used to embed photos in entries"
      },
      "bundleIdentifier": "com.devplex.verso"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "SCHEDULE_EXACT_ALARM",
        "READ_MEDIA_IMAGES"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.devplex.verso"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-sharing",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
