{
  "expo": {
    "name": "Verso",
    "slug": "verso",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "verso",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for voice dictation",
        "NSLocationWhenInUseUsageDescription": "Used to tag entries with your location",
        "NSPhotoLibraryUsageDescription": "Used to embed photos in entries",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.devplex.verso"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "SCHEDULE_EXACT_ALARM",
        "READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.devplex.verso"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [],
          "icon": "./assets/images/android-icon-monochrome.png"
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-audio",
      [
        "expo-updates",
        {
          "username": "devplex"
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "./plugins/withBeatunesMavenRepo"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5a01d060-5875-400f-aebd-92d5ccfaea46",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "5a01d060-5875-400f-aebd-92d5ccfaea46"
      }
    }
  }
}
