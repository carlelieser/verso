+package com.swmansion.enriched.textinput.events
+
+import com.facebook.react.bridge.Arguments
+import com.facebook.react.bridge.WritableMap
+import com.facebook.react.uimanager.events.Event
+
+class OnInputScrollEvent(
+  surfaceId: Int,
+  viewId: Int,
+  private val scrollY: Float,
+  private val contentHeight: Float,
+  private val layoutHeight: Float,
+  private val experimentalSynchronousEvents: Boolean,
+) : Event<OnInputScrollEvent>(surfaceId, viewId) {
+  override fun getEventName(): String = EVENT_NAME
+
+  override fun getEventData(): WritableMap {
+    val eventData: WritableMap = Arguments.createMap()
+    eventData.putDouble("scrollY", scrollY.toDouble())
+    eventData.putDouble("contentHeight", contentHeight.toDouble())
+    eventData.putDouble("layoutHeight", layoutHeight.toDouble())
+
+    return eventData
+  }
+
+  override fun experimental_isSynchronous(): Boolean = experimentalSynchronousEvents
+
+  companion object {
+    const val EVENT_NAME: String = "onInputScroll"
+  }
+}
